#!/usr/bin/env php
<?php

use Fabiom\UglyDuckling\Framework\DataBase\Migrations\MigrationRepository;
use Fabiom\UglyDuckling\Framework\DataBase\Migrations\Migrator;
use Fabiom\UglyDuckling\Framework\DataBase\Seeders\SeederRunner;

// Locate vendor/autoload.php whether run from library root or installed as a dependency
$autoloadCandidates = [
        __DIR__ . '/../vendor/autoload.php',    // library development root
        __DIR__ . '/../../../autoload.php',     // installed inside vendor/fabiomattei/uglyduckling/
];

$autoloaded = false;
foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        require $candidate;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Error: could not find vendor/autoload.php\n");
    exit(1);
}

/**
 * Picks a migration stub and the table name to fill into it based on the migration
 * name slug, mirroring Laravel's make:migration table inference:
 *   create_books_table          -> create_table.stub, table "books"
 *   add_isbn_to_books_table     -> table.stub,         table "books"
 *   remove_isbn_from_books_table -> table.stub,        table "books"
 *   anything else               -> migration.stub,     no table substitution
 *
 * @return array{0: string, 1: ?string} [stub file path, inferred table name]
 */
function ud_migrate_resolve_stub(string $slug): array {
    $stubsDir = __DIR__ . '/../src/Framework/DataBase/Migrations/stubs';

    if (preg_match('/^create_(.+)_table$/', $slug, $matches)) {
        return [$stubsDir . '/create_table.stub', $matches[1]];
    }

    if (preg_match('/^(?:add|remove|drop)_.+_(?:to|from)_(.+)_table$/', $slug, $matches)) {
        return [$stubsDir . '/table.stub', $matches[1]];
    }

    return [$stubsDir . '/migration.stub', null];
}

const UD_MIGRATE_USAGE = <<<USAGE
Usage:
  ud-migrate migrate  [config-file] [migrations-dir]   Run every pending migration
  ud-migrate rollback [--step=N] [config-file] [migrations-dir]
                                                        Revert the last batch of migrations,
                                                        or the last N migrations with --step
  ud-migrate refresh  [config-file] [migrations-dir]   Revert every migration (via down()), then migrate
  ud-migrate fresh    [config-file] [migrations-dir]   Drop every table, then migrate from scratch
  ud-migrate status   [config-file] [migrations-dir]   Show which migrations have run
  ud-migrate make <name> [migrations-dir]               Create a new migration file
  ud-migrate seed [--class=Name] [config-file] [seeders-dir]
                                                        Run every seeder, or just one with --class
  ud-migrate make-seeder <name> [seeders-dir]           Create a new seeder file

Defaults:
  config-file     ./migrations-config.php  (a PHP file that must `return` a PDO instance)
  migrations-dir  ./database/migrations
  seeders-dir     ./database/seeders

USAGE;

$command = $argv[1] ?? null;

if (!in_array($command, ['migrate', 'rollback', 'refresh', 'fresh', 'status', 'make', 'seed', 'make-seeder'], true)) {
    fwrite(STDERR, UD_MIGRATE_USAGE);
    exit(1);
}

$steps = null;
if ($command === 'rollback') {
    foreach ($argv as $index => $arg) {
        if (preg_match('/^--step=(\d+)$/', $arg, $matches)) {
            $steps = (int) $matches[1];
            unset($argv[$index]);
        }
    }
    $argv = array_values($argv);
}

$seederClass = null;
if ($command === 'seed') {
    foreach ($argv as $index => $arg) {
        if (preg_match('/^--class=(.+)$/', $arg, $matches)) {
            $seederClass = $matches[1];
            unset($argv[$index]);
        }
    }
    $argv = array_values($argv);
}

if ($command === 'make') {
    $name = $argv[2] ?? null;
    if ($name === null || trim($name) === '') {
        fwrite(STDERR, "Error: migration name required\n\n" . UD_MIGRATE_USAGE);
        exit(1);
    }

    $migrationsDir = rtrim($argv[3] ?? getcwd() . '/database/migrations', DIRECTORY_SEPARATOR);
    if (!is_dir($migrationsDir) && !mkdir($migrationsDir, 0777, true) && !is_dir($migrationsDir)) {
        fwrite(STDERR, "Error: could not create migrations directory: $migrationsDir\n");
        exit(1);
    }

    $slug = strtolower(trim(preg_replace('/[^A-Za-z0-9]+/', '_', $name), '_'));
    $filename = date('Y_m_d_His') . '_' . $slug . '.php';
    $path = $migrationsDir . DIRECTORY_SEPARATOR . $filename;

    [$stub, $table] = ud_migrate_resolve_stub($slug);
    $contents = file_get_contents($stub);
    if ($table !== null) {
        $contents = str_replace('{{table}}', $table, $contents);
    }
    file_put_contents($path, $contents);

    echo "Created migration: $path\n";
    exit(0);
}

if ($command === 'make-seeder') {
    $name = $argv[2] ?? null;
    if ($name === null || trim($name) === '') {
        fwrite(STDERR, "Error: seeder name required\n\n" . UD_MIGRATE_USAGE);
        exit(1);
    }

    $seedersDir = rtrim($argv[3] ?? getcwd() . '/database/seeders', DIRECTORY_SEPARATOR);
    if (!is_dir($seedersDir) && !mkdir($seedersDir, 0777, true) && !is_dir($seedersDir)) {
        fwrite(STDERR, "Error: could not create seeders directory: $seedersDir\n");
        exit(1);
    }

    $slug = strtolower(trim(preg_replace('/[^A-Za-z0-9]+/', '_', $name), '_'));
    $filename = date('Y_m_d_His') . '_' . $slug . '.php';
    $path = $seedersDir . DIRECTORY_SEPARATOR . $filename;

    copy(__DIR__ . '/../src/Framework/DataBase/Seeders/stubs/seeder.stub', $path);

    echo "Created seeder: $path\n";
    exit(0);
}

$configPath = $argv[2] ?? getcwd() . DIRECTORY_SEPARATOR . 'migrations-config.php';
$defaultResourceDir = $command === 'seed'
    ? getcwd() . DIRECTORY_SEPARATOR . 'database' . DIRECTORY_SEPARATOR . 'seeders'
    : getcwd() . DIRECTORY_SEPARATOR . 'database' . DIRECTORY_SEPARATOR . 'migrations';
$migrationsDir = $argv[3] ?? $defaultResourceDir;

if (!file_exists($configPath)) {
    fwrite(STDERR, "Error: config file not found: $configPath\n\n" . UD_MIGRATE_USAGE);
    exit(1);
}

$pdo = require $configPath;

if (!$pdo instanceof PDO) {
    fwrite(STDERR, "Error: $configPath must `return` a PDO instance\n");
    exit(1);
}

if (!is_dir($migrationsDir)) {
    $label = $command === 'seed' ? 'seeders' : 'migrations';
    fwrite(STDERR, "Error: $label directory not found: $migrationsDir\n");
    exit(1);
}

if ($command === 'seed') {
    $seederRunner = new SeederRunner($pdo, $migrationsDir);

    try {
        if ($seederClass !== null) {
            $seederRunner->runOne($seederClass);
            echo "Seeded: $seederClass\n";
        } else {
            $ran = $seederRunner->run();
            if (empty($ran)) {
                echo "No seeders found.\n";
            } else {
                foreach ($ran as $seederName) {
                    echo "Seeded: $seederName\n";
                }
            }
        }
    } catch (\Throwable $e) {
        fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n");
        exit(1);
    }

    exit(0);
}

$migrator = new Migrator($pdo, new MigrationRepository($pdo), $migrationsDir);

try {
    switch ($command) {
        case 'migrate':
            $ran = $migrator->migrate();
            if (empty($ran)) {
                echo "Nothing to migrate.\n";
            } else {
                foreach ($ran as $migrationName) {
                    echo "Migrated:  $migrationName\n";
                }
            }
            break;

        case 'rollback':
            $rolledBack = $migrator->rollback($steps);
            if (empty($rolledBack)) {
                echo "Nothing to roll back.\n";
            } else {
                foreach ($rolledBack as $migrationName) {
                    echo "Rolled back: $migrationName\n";
                }
            }
            break;

        case 'refresh':
            $ran = $migrator->refresh();
            echo "Database refreshed.\n";
            foreach ($ran as $migrationName) {
                echo "Migrated:  $migrationName\n";
            }
            break;

        case 'fresh':
            $ran = $migrator->fresh();
            echo "Database dropped and migrated fresh.\n";
            foreach ($ran as $migrationName) {
                echo "Migrated:  $migrationName\n";
            }
            break;

        case 'status':
            foreach ($migrator->status() as $entry) {
                echo '[' . ($entry['ran'] ? 'X' : ' ') . '] ' . $entry['migration'] . "\n";
            }
            break;
    }
} catch (\Throwable $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n");
    exit(1);
}

exit(0);
